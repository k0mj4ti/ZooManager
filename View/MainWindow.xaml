<Window x:Class="ZooManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZooManager" 
        xmlns:view="clr-namespace:ZooManager.View"
        mc:Ignorable="d"
        Title="ZooManager" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="{Binding AnimalCount}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox Grid.Row="1" Grid.Column="0" ItemsSource="{Binding Animals}" SelectedItem="{Binding SelectedAnimal}" Margin="0,0,10,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <view:AnimalDisplay/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock Text="Új állat adatai" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Text="Név:"/>
            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
            <TextBlock Text="Faj:"/>
            <TextBox Text="{Binding NewSpecies, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
            <TextBlock Text="Kor (év):"/>
            <TextBox Text="{Binding NewAge, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
            <TextBlock Text="Súly (kg):"/>
            <TextBox Text="{Binding NewWeight, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
            <CheckBox IsChecked="{Binding NewIsEndangered, UpdateSourceTrigger=PropertyChanged}" Content="Veszélyeztetett" Margin="0,5,0,10"/>
            <Button Content="Hozzáadás" Command="{Binding AddAnimalCommand}" Padding="10,5"/>
        </StackPanel>

        <Button Grid.Row="2" Grid.Column="0" Content="Kijelölt állat törlése" Command="{Binding RemoveAnimalCommand}" Margin="0,10,10,0" Padding="10,5"/>
    </Grid>
</Window>   